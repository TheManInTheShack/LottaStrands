[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://scenes/TitleCard.gd" id="1"]

; LOTTA STRANDS font — swap for a custom .ttf for best results
; Recommended: Boogaloo, Righteous, or Monoton from Google Fonts
; Drop the .ttf into godot/fonts/ and change this to:
;   [ext_resource type="FontFile" path="res://fonts/YourFont.ttf" id="FontFile_title"]
; then set theme_override_fonts/font = ExtResource("FontFile_title") on TitleLine1
[sub_resource type="SystemFont" id="SystemFont_title"]
font_names = PackedStringArray("Impact", "Arial Black", "Liberation Sans Bold")
font_weight = 900
font_italic = true

; Monospace subtitle font
[sub_resource type="SystemFont" id="SystemFont_mono"]
font_names = PackedStringArray("Courier New", "Liberation Mono", "DejaVu Sans Mono", "monospace")

[node name="TitleCard" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1")

[node name="BG" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0, 0, 0, 1)

[node name="TitleContainer" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -400.0
offset_top = -80.0
offset_right = 400.0
offset_bottom = 80.0
theme_override_constants/separation = 12
alignment = 1

[node name="TitleLine1" type="Label" parent="TitleContainer"]
layout_mode = 2
size_flags_horizontal = 4
theme_override_fonts/font = SubResource("SystemFont_title")
theme_override_font_sizes/font_size = 64
theme_override_colors/font_color = Color(1, 1, 1, 1)
text = "LOTTA STRANDS"
horizontal_alignment = 1

[node name="TitleLine2" type="Label" parent="TitleContainer"]
layout_mode = 2
size_flags_horizontal = 4
theme_override_fonts/font = SubResource("SystemFont_mono")
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.8, 0.8, 0.8, 1)
text = "a context rich model of The Big Lebowski"
horizontal_alignment = 1
